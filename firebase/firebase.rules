rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /big2LeaderboardPlayers/{docId} {
      allow read: if true;
      allow create: if isValidCreate(docId);
      allow update: if isValidUpdate(docId);
      allow delete: if false;
    }
    match /big2Rooms/{roomId} {
      allow read: if true;
      allow create: if isValidRoomData(request.resource.data);
      allow update: if isValidRoomData(request.resource.data) &&
        (
          (resource.data.status == 'playing' &&
            request.resource.data.players.size() <= resource.data.players.size() &&
            request.resource.data.gameVersion is int &&
            request.resource.data.gameVersion == resource.data.gameVersion + 1)
          ||
          (resource.data.status != 'playing' &&
            request.resource.data.gameVersion is int &&
            request.resource.data.gameVersion == resource.data.gameVersion)
        );
      allow delete: if false;
    }
    match /big2Users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid && isValidUserDoc(request.resource.data);
      allow update: if request.auth != null && request.auth.uid == uid && isValidUserDoc(request.resource.data);
      allow delete: if false;
    }
    match /big2GameLogs/{logId} {
      allow read: if true;
      allow create: if isValidGameLog(request.resource.data);
      allow update: if isValidGameLog(request.resource.data);
      allow delete: if false;
    }
  }

  function topLevelAllowedKeys() {
    return [
      'id',
      'name',
      'email',
      'gender',
      'picture',
      'settings',
      'totalScore',
      'games',
      'wins',
      'updatedAt'
    ];
  }

  function settingsAllowedKeys() {
    return [
      'language',
      'aiDifficulty',
      'backColor',
      'soundEnabled',
      'calloutDisplayEnabled',
      'calloutVoiceMode',
      'calloutStylePack',
      'voiceMode',
      'gender',
      'avatarChoice',
      'theme',
      'turnTimeout'
    ];
  }

  function isValidLanguage(v) {
    return v == 'zh-HK' || v == 'en';
  }

  function isValidDifficulty(v) {
    return v == 'easy' || v == 'normal' || v == 'hard';
  }

  function isValidBackColor(v) {
    return
      v == 'blue' ||
      v == 'red' ||
      v == 'green' ||
      v == 'gold' ||
      v == 'purple';
  }

  function isValidVoiceMode(v) {
    return
      v == 'auto' ||
      v == 'recorded' ||
      v == 'tts' ||
      v == 'off';
  }
  function isValidCalloutStylePack(v) {
    return v == 'classic' || v == 'energetic' || v == 'minimal';
  }

  function isValidGender(v) {
    return v == 'male' || v == 'female';
  }

  function isValidAvatarChoice(v) {
    return v == 'male' || v == 'female' || v == 'google';
  }

  function isValidTheme(v) {
    return
      v == 'ocean' ||
      v == 'emerald' ||
      v == 'sunset' ||
      v == 'slate' ||
      v == 'aurora' ||
      v == 'sand' ||
      v == 'cyber';
  }

  function isValidSettings(s) {
    return
      s is map &&
      s.keys().hasOnly(settingsAllowedKeys()) &&
      (!('language' in s) || (s.language is string && isValidLanguage(s.language))) &&
      (!('aiDifficulty' in s) || (s.aiDifficulty is string && isValidDifficulty(s.aiDifficulty))) &&
      (!('backColor' in s) || (s.backColor is string && isValidBackColor(s.backColor))) &&
      (!('soundEnabled' in s) || s.soundEnabled is bool) &&
      (!('calloutDisplayEnabled' in s) || s.calloutDisplayEnabled is bool) &&
      (!('calloutVoiceMode' in s) || (s.calloutVoiceMode is string && isValidVoiceMode(s.calloutVoiceMode))) &&
      (!('calloutStylePack' in s) || (s.calloutStylePack is string && isValidCalloutStylePack(s.calloutStylePack))) &&
      (!('voiceMode' in s) || (s.voiceMode is string && isValidVoiceMode(s.voiceMode))) &&
      (!('gender' in s) || (s.gender is string && isValidGender(s.gender))) &&
      (!('avatarChoice' in s) || (s.avatarChoice is string && isValidAvatarChoice(s.avatarChoice))) &&
      (!('theme' in s) || (s.theme is string && isValidTheme(s.theme))) &&
      (!('turnTimeout' in s) || (s.turnTimeout is int && s.turnTimeout >= 5000 && s.turnTimeout <= 60000));
  }

  function roomAllowedKeys() {
    return [
      'hostId',
      'hostName',
      'code',
      'status',
      'createdAt',
      'updatedAt',
      'expiresAt',
      'maxPlayers',
      'players',
      'settings',
      'game',
      'gameVersion'
    ];
  }

  function isValidRoomStatus(v) {
    return v == 'lobby' || v == 'starting' || v == 'playing' || v == 'finished';
  }


  function isValidRoomData(d) {
    return
      d.keys().hasOnly(roomAllowedKeys()) &&
      d.hostId is string &&
      d.hostName is string &&
      d.code is string &&
      d.status is string && isValidRoomStatus(d.status) &&
      d.createdAt is int &&
      d.updatedAt is int &&
      (!('expiresAt' in d) || d.expiresAt is int) &&
      d.maxPlayers is int &&
      d.maxPlayers >= 2 &&
      d.maxPlayers <= 4 &&
      d.players is list &&
      d.players.size() >= 1 &&
      d.players.size() <= 4 &&
      (!('settings' in d) || isValidSettings(d.settings)) &&
      (!('game' in d) || d.game is map) &&
      (!('gameVersion' in d) || d.gameVersion is int);
  }


  function isValidBody(docId, d) {
    return
      d.id is string &&
      d.id == docId &&
      d.name is string &&
      d.name.size() >= 1 &&
      d.name.size() <= 32 &&

      (!('email' in d) || (d.email is string && d.email.size() <= 120)) &&
      (!('gender' in d) || (d.gender is string && isValidGender(d.gender))) &&
      (!('picture' in d) || (d.picture is string && d.picture.size() <= 1024)) &&

      d.totalScore is int &&
      d.totalScore >= 0 &&
      d.totalScore <= 100000000 &&
      d.games is int &&
      d.games >= 0 &&
      d.games <= 100000 &&
      d.wins is int &&
      d.wins >= 0 &&
      d.wins <= d.games &&

      d.updatedAt is int &&
      d.updatedAt >= request.time.toMillis() - 24 * 60 * 60 * 1000 &&
      d.updatedAt <= request.time.toMillis() + 24 * 60 * 60 * 1000 &&

      (!('settings' in d) || isValidSettings(d.settings));
  }

  function isValidCreate(docId) {
    let d = request.resource.data;
    return
      d.keys().hasOnly(topLevelAllowedKeys()) &&
      isValidBody(docId, d);
  }

  function isValidUpdate(docId) {
    let d = request.resource.data;
    let changed = d.diff(resource.data).affectedKeys();
    return
      changed.hasOnly(topLevelAllowedKeys()) &&
      isValidBody(docId, d);
  }

  function isValidUserDoc(d) {
    return
      d.keys().hasOnly(['currentRoomId','updatedAt']) &&
      (!('currentRoomId' in d) || d.currentRoomId is string) &&
      (!('updatedAt' in d) || d.updatedAt is int);
  }

  function isValidGameLog(d) {
    return
      d.keys().hasOnly(['roomId','gameVersion','status','createdAt','endedAt','settings','summary','players','totals','history']) &&
      d.roomId is string &&
      d.gameVersion is int &&
      d.createdAt is int &&
      d.endedAt is int;
  }
}
